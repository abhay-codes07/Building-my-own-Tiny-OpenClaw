# ─────────────────────────────────────────────────────────────────────────────
# Tiny-OpenClaw — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram bot token — create a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Optional (these defaults work out of the box) ────────────────────────────

# LLM provider (currently only "anthropic" is wired up)
MODEL_PROVIDER=anthropic

# Claude model to use — claude-opus-4-6 is the most capable
# Other options: claude-sonnet-4-6, claude-haiku-4-5-20251001
MODEL_NAME=claude-opus-4-6
